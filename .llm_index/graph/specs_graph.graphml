    <node id="05-testing-operations.testing-operations">
      <data key="d0">document</data>
      <data key="d1">doc: IoTable Testing and Operations</data>
      <data key="d2">IoTable Testing and Operations</data>
      <data key="d3">1.0.0</data>
      <data key="d4">draft</data>
      <data key="d5">05_testing_operations.yaml</data>
    </node>
    <node id="04-application-contracts.application-contracts">
      <data key="d0">document</data>
      <data key="d1">doc: IoTable Application Contracts</data>
      <data key="d2">IoTable Application Contracts</data>
      <data key="d3">1.0.0</data>
      <data key="d4">draft</data>
      <data key="d5">04_application_contracts.yaml</data>
    </node>
    <node id="MBR-001">
      <data key="d0">rule</data>
      <data key="d1">rule: MBR-001</data>
      <data key="d6">Business capability modules are the primary architecture boundary.</data>
      <data key="d7">module_boundary_rules</data>
    </node>
    <node id="MBR-002">
      <data key="d0">rule</data>
      <data key="d1">rule: MBR-002</data>
      <data key="d6">A module MUST own its application services, domain rules, data contracts, API contracts, and tests for its capability.</data>
      <data key="d7">module_boundary_rules</data>
    </node>
    <node id="MBR-003">
      <data key="d0">rule</data>
      <data key="d1">rule: MBR-003</data>
      <data key="d6">A module MUST NOT directly mutate another module's owned data.</data>
      <data key="d7">module_boundary_rules</data>
    </node>
    <node id="MBR-004">
      <data key="d0">rule</data>
      <data key="d1">rule: MBR-004</data>
      <data key="d6">Cross-module behavior MUST use explicit application contracts, domain events, or documented integration points.</data>
      <data key="d7">module_boundary_rules</data>
    </node>
    <node id="MBR-005">
      <data key="d0">rule</data>
      <data key="d1">rule: MBR-005</data>
      <data key="d6">Shared modules MUST provide infrastructure behavior and MUST NOT own product behavior decisions.</data>
      <data key="d7">module_boundary_rules</data>
    </node>
    <node id="MBR-006">
      <data key="d0">rule</data>
      <data key="d1">rule: MBR-006</data>
      <data key="d6">Platform-scope modules MUST NOT own tenant operational data.</data>
      <data key="d7">module_boundary_rules</data>
    </node>
    <node id="MBR-007">
      <data key="d0">rule</data>
      <data key="d1">rule: MBR-007</data>
      <data key="d6">Tenant-scope modules MUST NOT own platform control-plane data.</data>
      <data key="d7">module_boundary_rules</data>
    </node>
    <node id="CAR-001">
      <data key="d0">rule</data>
      <data key="d1">rule: CAR-001</data>
      <data key="d6">Each business module SHOULD be structured around domain, application, infrastructure, and presentation/API concerns.</data>
      <data key="d7">clean_architecture_rules</data>
    </node>
    <node id="CAR-002">
      <data key="d0">rule</data>
      <data key="d1">rule: CAR-002</data>
      <data key="d6">Domain rules MUST NOT depend on database, HTTP, UI, or framework-specific implementation details.</data>
      <data key="d7">clean_architecture_rules</data>
    </node>
    <node id="CAR-003">
      <data key="d0">rule</data>
      <data key="d1">rule: CAR-003</data>
      <data key="d6">Application services coordinate use cases and enforce module-level workflow rules.</data>
      <data key="d7">clean_architecture_rules</data>
    </node>
    <node id="CAR-004">
      <data key="d0">rule</data>
      <data key="d1">rule: CAR-004</data>
      <data key="d6">Infrastructure code implements persistence, external integrations, messaging, and framework adapters.</data>
      <data key="d7">clean_architecture_rules</data>
    </node>
    <node id="CAR-005">
      <data key="d0">rule</data>
      <data key="d1">rule: CAR-005</data>
      <data key="d6">API endpoints MUST call application services rather than directly mutating persistence models.</data>
      <data key="d7">clean_architecture_rules</data>
    </node>
    <node id="CAR-006">
      <data key="d0">rule</data>
      <data key="d1">rule: CAR-006</data>
      <data key="d6">Module tests MUST cover domain rules, application use cases, API contracts, and persistence boundaries when touched.</data>
      <data key="d7">clean_architecture_rules</data>
    </node>
    <node id="BSS-001">
      <data key="d0">rule</data>
      <data key="d1">rule: BSS-001</data>
      <data key="d6">Domain layers MUST NOT depend on Infrastructure or Api layers.</data>
      <data key="d7">project_dependency_rules</data>
    </node>
    <node id="BSS-002">
      <data key="d0">rule</data>
      <data key="d1">rule: BSS-002</data>
      <data key="d6">Application layers MUST NOT depend on Api layers.</data>
      <data key="d7">project_dependency_rules</data>
    </node>
    <node id="BSS-003">
      <data key="d0">rule</data>
      <data key="d1">rule: BSS-003</data>
      <data key="d6">Api layers MUST NOT contain domain behavior.</data>
      <data key="d7">project_dependency_rules</data>
    </node>
    <node id="BSS-004">
      <data key="d0">rule</data>
      <data key="d1">rule: BSS-004</data>
      <data key="d6">Infrastructure layers MAY depend on their own module Application and Domain layers.</data>
      <data key="d7">project_dependency_rules</data>
    </node>
    <node id="BSS-005">
      <data key="d0">rule</data>
      <data key="d1">rule: BSS-005</data>
      <data key="d6">FastAPI entrypoints MAY reference module Api and Infrastructure routers.</data>
      <data key="d7">project_dependency_rules</data>
    </node>
    <node id="BSS-006">
      <data key="d0">rule</data>
      <data key="d1">rule: BSS-006</data>
      <data key="d6">Cross-module direct Infrastructure layer dependency is forbidden.</data>
      <data key="d7">project_dependency_rules</data>
    </node>
    <node id="BSS-007">
      <data key="d0">rule</data>
      <data key="d1">rule: BSS-007</data>
      <data key="d6">Shared core packages MUST NOT contain IoTable product decisions.</data>
      <data key="d7">project_dependency_rules</data>
    </node>
    <node id="BSC-001">
      <data key="d0">rule</data>
      <data key="d1">rule: BSC-001</data>
      <data key="d6">Platform database connection configuration MUST be resolved by app.main and app.worker configurations.</data>
      <data key="d7">configuration_rules</data>
    </node>
    <node id="BSC-002">
      <data key="d0">rule</data>
      <data key="d1">rule: BSC-002</data>
      <data key="d6">Tenant database connection resolution MUST use tenant context and tenant database registry.</data>
      <data key="d7">configuration_rules</data>
    </node>
    <node id="BSC-003">
      <data key="d0">rule</data>
      <data key="d1">rule: BSC-003</data>
      <data key="d6">Secrets MUST NOT be stored in source code or specification examples.</data>
      <data key="d7">configuration_rules</data>
    </node>
    <node id="BSC-004">
      <data key="d0">rule</data>
      <data key="d1">rule: BSC-004</data>
      <data key="d6">Platform and tenant frontend applications MUST NOT be hosted inside backend repositories.</data>
      <data key="d7">configuration_rules</data>
    </node>
    <node id="BSC-005">
      <data key="d0">rule</data>
      <data key="d1">rule: BSC-005</data>
      <data key="d6">Redis configuration MUST be resolved by backend configuration and MUST be treated as ephemeral infrastructure.</data>
      <data key="d7">configuration_rules</data>
    </node>
    <node id="BSC-006">
      <data key="d0">rule</data>
      <data key="d1">rule: BSC-006</data>
      <data key="d6">Celery configuration MUST be resolved by app.worker configuration.</data>
      <data key="d7">configuration_rules</data>
    </node>
    <node id="FAS-001">
      <data key="d0">rule</data>
      <data key="d1">rule: FAS-001</data>
      <data key="d6">platform_web and tenant_web MUST be separate Next.js applications.</data>
      <data key="d7">isolation_rules</data>
    </node>
    <node id="FAS-002">
      <data key="d0">rule</data>
      <data key="d1">rule: FAS-002</data>
      <data key="d6">platform_web MUST be served only from platform.iotables.net.</data>
      <data key="d7">isolation_rules</data>
    </node>
    <node id="FAS-003">
      <data key="d0">rule</data>
      <data key="d1">rule: FAS-003</data>
      <data key="d6">tenant_web MUST be served only from tenant domains matching {tenant}.iotables.net.</data>
      <data key="d7">isolation_rules</data>
    </node>
    <node id="FAS-004">
      <data key="d0">rule</data>
      <data key="d1">rule: FAS-004</data>
      <data key="d6">platform_web MUST call only platform API routes under /api/platform/**.</data>
      <data key="d7">isolation_rules</data>
    </node>
    <node id="FAS-005">
      <data key="d0">rule</data>
      <data key="d1">rule: FAS-005</data>
      <data key="d6">tenant_web MUST NOT call platform API routes.</data>
      <data key="d7">isolation_rules</data>
    </node>
    <node id="FAS-006">
      <data key="d0">rule</data>
      <data key="d1">rule: FAS-006</data>
      <data key="d6">platform_web MUST NOT include tenant menu, order, station, checkout, or customer session screens.</data>
      <data key="d7">isolation_rules</data>
    </node>
    <node id="FAS-007">
      <data key="d0">rule</data>
      <data key="d1">rule: FAS-007</data>
      <data key="d6">tenant_web MUST NOT include tenant lifecycle, provisioning, schema job, platform settings, or platform audit screens.</data>
      <data key="d7">isolation_rules</data>
    </node>
    <node id="FAS-008">
      <data key="d0">rule</data>
      <data key="d1">rule: FAS-008</data>
      <data key="d6">Platform authentication state MUST be separate from tenant authentication state.</data>
      <data key="d7">isolation_rules</data>
    </node>
    <node id="FAS-009">
      <data key="d0">rule</data>
      <data key="d1">rule: FAS-009</data>
      <data key="d6">Platform cookies, tenant staff cookies, and customer guest continuity state MUST use separate names and scopes.</data>
      <data key="d7">isolation_rules</data>
    </node>
    <node id="FAS-010">
      <data key="d0">rule</data>
      <data key="d1">rule: FAS-010</data>
      <data key="d6">Shared UI code MAY exist only as framework-independent packages without product authorization behavior.</data>
      <data key="d7">isolation_rules</data>
    </node>
    <node id="FAS-018">
      <data key="d0">rule</data>
      <data key="d1">rule: FAS-018</data>
      <data key="d6">Inside both platform_web and tenant_web Next.js applications, every sub-route or route group MUST be structured as an isolated, self-contained domain module. A page folder MUST co-locate its private sub-components (under `_components/`), private hooks (under `_hooks/`), private state selectors, and private API fetchers (under `_api/`).</data>
      <data key="d7">isolation_rules</data>
    </node>
    <node id="FAS-019">
      <data key="d0">rule</data>
      <data key="d1">rule: FAS-019</data>
      <data key="d6">Page folders MUST NOT import components, hooks, state stores, or helper functions from other page folders. Direct relative imports crossing page boundaries are strictly prohibited. Page components MAY only import globally shared, stateless UI primitives under `src/components/ui/` or shared layout shells under `src/components/layout/`.</data>
      <data key="d7">isolation_rules</data>
    </node>
    <node id="TVB-001">
      <data key="d0">rule</data>
      <data key="d1">rule: TVB-001</data>
      <data key="d6">IoTable backend implementation MUST use Python 3.14 and FastAPI.</data>
      <data key="d7">binding_rules</data>
    </node>
    <node id="TVB-002">
      <data key="d0">rule</data>
      <data key="d1">rule: TVB-002</data>
      <data key="d6">IoTable frontend implementation MUST use Next.js 16.2.4 and React 19.2.5.</data>
      <data key="d7">binding_rules</data>
    </node>
    <node id="TVB-003">
      <data key="d0">rule</data>
      <data key="d1">rule: TVB-003</data>
      <data key="d6">IoTable frontend implementation MUST use TypeScript 6.0.3.</data>
      <data key="d7">binding_rules</data>
    </node>
    <node id="TVB-004">
      <data key="d0">rule</data>
      <data key="d1">rule: TVB-004</data>
      <data key="d6">IoTable frontend styling baseline MUST use Tailwind CSS v4.0.</data>
      <data key="d7">binding_rules</data>
    </node>
    <node id="TVB-005">
      <data key="d0">rule</data>
      <data key="d1">rule: TVB-005</data>
      <data key="d6">IoTable Node tooling MUST use Node.js 24 LTS and pnpm 11.0.3.</data>
      <data key="d7">binding_rules</data>
    </node>
    <node id="TVB-006">
      <data key="d0">rule</data>
      <data key="d1">rule: TVB-006</data>
      <data key="d6">IoTable persistent relational storage MUST use PostgreSQL 17.</data>
      <data key="d7">binding_rules</data>
    </node>
    <node id="TVB-007">
      <data key="d0">rule</data>
      <data key="d1">rule: TVB-007</data>
      <data key="d6">IoTable frontend deployables MUST remain Next.js applications named platform_web and tenant_web.</data>
      <data key="d7">binding_rules</data>
    </node>
    <node id="TVB-008">
      <data key="d0">rule</data>
      <data key="d1">rule: TVB-008</data>
      <data key="d6">A version change in this baseline MUST update every dependent architecture, implementation, testing, and deployment specification in the same specification change.</data>
      <data key="d7">binding_rules</data>
    </node>
    <node id="FAS-011">
      <data key="d0">rule</data>
      <data key="d1">rule: FAS-011</data>
      <data key="d6">Multi-tenant SSL certificates MUST be provisioned dynamically and automatically using Caddy On-Demand TLS.</data>
      <data key="d7">rules</data>
    </node>
    <node id="FAS-012">
      <data key="d0">rule</data>
      <data key="d1">rule: FAS-012</data>
      <data key="d6">The reverse proxy MUST validate the existence of the tenant slug via the platform API before completing the TLS handshake.</data>
      <data key="d7">rules</data>
    </node>
    <node id="FAS-013">
      <data key="d0">rule</data>
      <data key="d1">rule: FAS-013</data>
      <data key="d6">Subdomain routing MUST map {tenant}.iotables.net/app/** and /console/** to the tenant_web Next.js application.</data>
      <data key="d7">rules</data>
    </node>
    <node id="FAS-014">
      <data key="d0">rule</data>
      <data key="d1">rule: FAS-014</data>
      <data key="d6">Platform routing MUST map platform.iotables.net/** to the platform_web Next.js application.</data>
      <data key="d7">rules</data>
    </node>
    <node id="FAS-015">
      <data key="d0">rule</data>
      <data key="d1">rule: FAS-015</data>
      <data key="d6">Frontend UI MUST dynamically resolve user theme preferences (light/dark mode) and store it locally.</data>
      <data key="d7">rules</data>
    </node>
    <node id="FAS-016">
      <data key="d0">rule</data>
      <data key="d1">rule: FAS-016</data>
      <data key="d6">Brand colors and background variables MUST strictly use HSL/Hex values defined in ui_design_system_tokens.</data>
      <data key="d7">rules</data>
    </node>
    <node id="FAS-017">
      <data key="d0">rule</data>
      <data key="d1">rule: FAS-017</data>
      <data key="d6">Interactive UI elements MUST use micro-animations with transition-duration of 200ms and ease-in-out timing function.</data>
      <data key="d7">rules</data>
    </node>
    <node id="MDR-001">
      <data key="d0">rule</data>
      <data key="d1">rule: MDR-001</data>
      <data key="d6">A module MUST own its primary data contracts.</data>
      <data key="d7">module_dependency_rules</data>
    </node>
    <node id="MDR-002">
      <data key="d0">rule</data>
      <data key="d1">rule: MDR-002</data>
      <data key="d6">A module MUST NOT write another module's owned data except through that module's defined API or application service contract.</data>
      <data key="d7">module_dependency_rules</data>
    </node>
    <node id="MDR-003">
      <data key="d0">rule</data>
      <data key="d1">rule: MDR-003</data>
      <data key="d6">Platform-scope modules MUST NOT directly own tenant operational data.</data>
      <data key="d7">module_dependency_rules</data>
    </node>
    <node id="MDR-004">
      <data key="d0">rule</data>
      <data key="d1">rule: MDR-004</data>
      <data key="d6">Tenant-scope modules MUST NOT directly own platform control-plane data.</data>
      <data key="d7">module_dependency_rules</data>
    </node>
    <node id="MDR-005">
      <data key="d0">rule</data>
      <data key="d1">rule: MDR-005</data>
      <data key="d6">Shared modules MUST provide infrastructure behavior without owning business decisions.</data>
      <data key="d7">module_dependency_rules</data>
    </node>
    <node id="MDR-006">
      <data key="d0">rule</data>
      <data key="d1">rule: MDR-006</data>
      <data key="d6">Excluded modules MUST remain out of implementation scope unless a new owner decision changes the product baseline.</data>
      <data key="d7">module_dependency_rules</data>
    </node>
    <node id="SWR-001">
      <data key="d0">rule</data>
      <data key="d1">rule: SWR-001</data>
      <data key="d6">Every YAML specification file MUST declare its matching JSON Schema path.</data>
      <data key="d7">specification_write_rules</data>
    </node>
    <node id="SWR-002">
      <data key="d0">rule</data>
      <data key="d1">rule: SWR-002</data>
      <data key="d6">Every specification file MUST be written as current final system state.</data>
      <data key="d7">specification_write_rules</data>
    </node>
    <node id="SWR-003">
      <data key="d0">rule</data>
      <data key="d1">rule: SWR-003</data>
      <data key="d6">Every added field MUST be represented in the matching schema.</data>
      <data key="d7">specification_write_rules</data>
    </node>
    <node id="SWR-004">
      <data key="d0">rule</data>
      <data key="d1">rule: SWR-004</data>
      <data key="d6">Every open product behavior MUST be recorded as an open decision.</data>
      <data key="d7">specification_write_rules</data>
    </node>
    <node id="SWR-005">
      <data key="d0">rule</data>
      <data key="d1">rule: SWR-005</data>
      <data key="d6">Every implementation task MUST include done_when criteria before it can be used by a coding agent.</data>
      <data key="d7">specification_write_rules</data>
    </node>
    <node id="SWR-006">
      <data key="d0">rule</data>
      <data key="d1">rule: SWR-006</data>
      <data key="d6">All repository-level documentation and technical specifications MUST be written exclusively in structured formats (such as YAML, JSON Schema, and ETL-compiled binary indexes) designed for AI/LLM consumption. Human-oriented Markdown (.md) or text (.txt) files are strictly prohibited inside the codebase root to prevent documentation drift and minimize LLM context token overhead.</data>
      <data key="d7">specification_write_rules</data>
    </node>
    <node id="ITER-001">
      <data key="d0">rule</data>
      <data key="d1">rule: ITER-001</data>
      <data key="d6">The coding agent MUST implement tasks in dependency order.</data>
      <data key="d7">implementation_task_execution_rules</data>
    </node>
    <node id="ITER-002">
      <data key="d0">rule</data>
      <data key="d1">rule: ITER-002</data>
      <data key="d6">The coding agent MUST NOT implement unspecified API behavior.</data>
      <data key="d7">implementation_task_execution_rules</data>
    </node>
    <node id="ITER-003">
      <data key="d0">rule</data>
      <data key="d1">rule: ITER-003</data>
      <data key="d6">The coding agent MUST NOT add packages that are not allowed by the specification.</data>
      <data key="d7">implementation_task_execution_rules</data>
    </node>
    <node id="ITER-004">
      <data key="d0">rule</data>
      <data key="d1">rule: ITER-004</data>
      <data key="d6">The coding agent MUST run verification commands when specified.</data>
      <data key="d7">implementation_task_execution_rules</data>
    </node>
    <node id="ITER-005">
      <data key="d0">rule</data>
      <data key="d1">rule: ITER-005</data>
      <data key="d6">The coding agent MUST report a blocker instead of guessing.</data>
      <data key="d7">implementation_task_execution_rules</data>
    </node>
    <node id="SUR-001">
      <data key="d0">rule</data>
      <data key="d1">rule: SUR-001</data>
      <data key="d6">A source is evidence, not inspiration.</data>
      <data key="d7">source_usage_rules</data>
    </node>
    <node id="SUR-002">
      <data key="d0">rule</data>
      <data key="d1">rule: SUR-002</data>
      <data key="d6">Product behavior MUST come from a project owner decision or an owner-accepted product source.</data>
      <data key="d7">source_usage_rules</data>
    </node>
    <node id="SUR-003">
      <data key="d0">rule</data>
      <data key="d1">rule: SUR-003</data>
      <data key="d6">Technical facts that are version-sensitive MUST be checked against current authoritative sources before entering the specification.</data>
      <data key="d7">source_usage_rules</data>
    </node>
    <node id="SUR-004">
      <data key="d0">rule</data>
      <data key="d1">rule: SUR-004</data>
      <data key="d6">Reference products MAY influence comparison, but MUST NOT be copied as requirements.</data>
      <data key="d7">source_usage_rules</data>
    </node>
    <node id="SUR-005">
      <data key="d0">rule</data>
      <data key="d1">rule: SUR-005</data>
      <data key="d6">A source conflict MUST be recorded as a decision item before the specification is frozen.</data>
      <data key="d7">source_usage_rules</data>
    </node>
    <node id="SUR-006">
      <data key="d0">rule</data>
      <data key="d1">rule: SUR-006</data>
      <data key="d6">No requirement may depend on external context that is not represented in the repository.</data>
      <data key="d7">source_usage_rules</data>
    </node>
    <node id="TT-001">
      <data key="d0">rule</data>
      <data key="d1">rule: TT-001</data>
      <data key="d6">Every implementation task MUST identify the verification tiers affected by the task.</data>
      <data key="d7">taxonomy_rules</data>
    </node>
    <node id="TT-002">
      <data key="d0">rule</data>
      <data key="d1">rule: TT-002</data>
      <data key="d6">A task that changes a public or internal API contract MUST include API contract verification.</data>
      <data key="d7">taxonomy_rules</data>
    </node>
    <node id="TT-003">
      <data key="d0">rule</data>
      <data key="d1">rule: TT-003</data>
      <data key="d6">A task that changes database schema, indexes, constraints, seed data, or ownership rules MUST include database contract verification.</data>
      <data key="d7">taxonomy_rules</data>
    </node>
    <node id="TT-004">
      <data key="d0">rule</data>
      <data key="d1">rule: TT-004</data>
      <data key="d6">A task that changes authentication, authorization, customer access, device identity, token handling, or secret handling MUST include security verification.</data>
      <data key="d7">taxonomy_rules</data>
    </node>
    <node id="TT-005">
      <data key="d0">rule</data>
      <data key="d1">rule: TT-005</data>
      <data key="d6">A task that changes a user-facing workflow MUST include workflow-level verification.</data>
      <data key="d7">taxonomy_rules</data>
    </node>
    <node id="TT-006">
      <data key="d0">rule</data>
      <data key="d1">rule: TT-006</data>
      <data key="d6">A task that changes deployment, health checks, configuration, background jobs, or recovery behavior MUST include operational verification.</data>
      <data key="d7">taxonomy_rules</data>
    </node>
    <node id="TT-007">
      <data key="d0">rule</data>
      <data key="d1">rule: TT-007</data>
      <data key="d6">Specification validation MUST pass before implementation verification is considered complete.</data>
      <data key="d7">taxonomy_rules</data>
    </node>
    <node id="HC-001">
      <data key="d0">rule</data>
      <data key="d1">rule: HC-001</data>
      <data key="d6">IoTable backend MUST expose /health, /health/live, and /health/ready.</data>
      <data key="d7">rules</data>
    </node>
    <node id="HC-002">
      <data key="d0">rule</data>
      <data key="d1">rule: HC-002</data>
      <data key="d6">/health MUST behave as a liveness-compatible alias.</data>
      <data key="d7">rules</data>
    </node>
    <node id="HC-003">
      <data key="d0">rule</data>
      <data key="d1">rule: HC-003</data>
      <data key="d6">/health/live MUST NOT fail because of database, cache, background job, or external dependency unavailability.</data>
      <data key="d7">rules</data>
    </node>
    <node id="HC-004">
      <data key="d0">rule</data>
      <data key="d1">rule: HC-004</data>
      <data key="d6">/health/ready MUST fail when a required dependency prevents safe request handling.</data>
      <data key="d7">rules</data>
    </node>
    <node id="HC-LIVE-001">
      <data key="d0">rule</data>
      <data key="d1">rule: HC-LIVE-001</data>
      <data key="d6">Liveness MUST check process responsiveness, not business readiness.</data>
      <data key="d7">rules</data>
    </node>
    <node id="HC-LIVE-002">
      <data key="d0">rule</data>
      <data key="d1">rule: HC-LIVE-002</data>
      <data key="d6">A temporary database outage MUST NOT cause /health/live to fail.</data>
      <data key="d7">rules</data>
    </node>
    <node id="HC-LIVE-003">
      <data key="d0">rule</data>
      <data key="d1">rule: HC-LIVE-003</data>
      <data key="d6">A saturated background job queue MUST NOT cause /health/live to fail.</data>
      <data key="d7">rules</data>
    </node>
    <node id="HC-READY-001">
      <data key="d0">rule</data>
      <data key="d1">rule: HC-READY-001</data>
      <data key="d6">Readiness MUST verify dependencies required for safe request handling.</data>
      <data key="d7">rules</data>
    </node>
    <node id="HC-READY-002">
      <data key="d0">rule</data>
      <data key="d1">rule: HC-READY-002</data>
      <data key="d6">Readiness MUST fail when the required database for the addressed scope is unreachable.</data>
      <data key="d7">rules</data>
    </node>
    <node id="HC-READY-003">
      <data key="d0">rule</data>
      <data key="d1">rule: HC-READY-003</data>
      <data key="d6">Readiness MUST fail when required migrations are not applied.</data>
      <data key="d7">rules</data>
    </node>
    <node id="HC-READY-004">
      <data key="d0">rule</data>
      <data key="d1">rule: HC-READY-004</data>
      <data key="d6">Readiness MUST fail when required runtime configuration is missing.</data>
      <data key="d7">rules</data>
    </node>
    <node id="HC-READY-005">
      <data key="d0">rule</data>
      <data key="d1">rule: HC-READY-005</data>
      <data key="d6">Readiness MUST NOT include business-state checks such as open order count, active table count, menu item count, or tenant revenue.</data>
      <data key="d7">rules</data>
    </node>
    <node id="HC-READY-006">
      <data key="d0">rule</data>
      <data key="d1">rule: HC-READY-006</data>
      <data key="d6">A readiness request for platform.iotables.net MUST evaluate platform-scope readiness.</data>
      <data key="d7">rules</data>
    </node>
    <node id="HC-READY-007">
      <data key="d0">rule</data>
      <data key="d1">rule: HC-READY-007</data>
      <data key="d6">A readiness request for a tenant host matching {tenant}.iotables.net MUST evaluate readiness for that resolved tenant.</data>
      <data key="d7">rules</data>
    </node>
    <node id="HC-READY-008">
      <data key="d0">rule</data>
      <data key="d1">rule: HC-READY-008</data>
      <data key="d6">Release verification MUST check readiness for platform.iotables.net and at least one provisioned active tenant host.</data>
      <data key="d7">rules</data>
    </node>
    <node id="HC-RESP-001">
      <data key="d0">rule</data>
      <data key="d1">rule: HC-RESP-001</data>
      <data key="d6">Health responses MUST use application/health+json.</data>
      <data key="d7">rules</data>
    </node>
    <node id="HC-RESP-002">
      <data key="d0">rule</data>
      <data key="d1">rule: HC-RESP-002</data>
      <data key="d6">Health responses MUST include status, service, version, releaseId, and checks.</data>
      <data key="d7">rules</data>
    </node>
    <node id="HC-RESP-003">
      <data key="d0">rule</data>
      <data key="d1">rule: HC-RESP-003</data>
      <data key="d6">A failed health response MUST use HTTP 503.</data>
      <data key="d7">rules</data>
    </node>
    <node id="HC-RESP-004">
      <data key="d0">rule</data>
      <data key="d1">rule: HC-RESP-004</data>
      <data key="d6">A health response MUST NOT include secrets, connection strings, token values, customer session identifiers, bill content, order content, or firmware secrets.</data>
      <data key="d7">rules</data>
    </node>
    <node id="HC-EXP-001">
      <data key="d0">rule</data>
      <data key="d1">rule: HC-EXP-001</data>
      <data key="d6">/health and /health/live MAY be exposed through the reverse proxy for uptime monitoring.</data>
      <data key="d7">rules</data>
    </node>
    <node id="HC-EXP-002">
      <data key="d0">rule</data>
      <data key="d1">rule: HC-EXP-002</data>
      <data key="d6">/health/ready MUST be restricted to trusted operational callers because readiness detail can expose internal dependency names.</data>
      <data key="d7">rules</data>
    </node>
    <node id="HC-EXP-003">
      <data key="d0">rule</data>
      <data key="d1">rule: HC-EXP-003</data>
      <data key="d6">Health endpoints MUST NOT require platform_owner or tenant staff authentication when called by trusted operational infrastructure.</data>
      <data key="d7">rules</data>
    </node>
    <node id="HC-RG-001">
      <data key="d0">rule</data>
      <data key="d1">rule: HC-RG-001</data>
      <data key="d6">Release verification MUST include liveness and readiness checks against the deployed backend.</data>
      <data key="d7">rules</data>
    </node>
    <node id="HC-RG-002">
      <data key="d0">rule</data>
      <data key="d1">rule: HC-RG-002</data>
      <data key="d6">Release verification MUST prove that readiness can fail closed for a required dependency.</data>
      <data key="d7">rules</data>
    </node>
    <node id="SLO-REC-001">
      <data key="d0">rule</data>
      <data key="d1">rule: SLO-REC-001</data>
      <data key="d6">Backups MUST be retained for 30 days.</data>
      <data key="d7">rules</data>
    </node>
    <node id="SLO-REC-002">
      <data key="d0">rule</data>
      <data key="d1">rule: SLO-REC-002</data>
      <data key="d6">IoTable recovery point objective MUST be 24 hours.</data>
      <data key="d7">rules</data>
    </node>
    <node id="SLO-REC-003">
      <data key="d0">rule</data>
      <data key="d1">rule: SLO-REC-003</data>
      <data key="d6">IoTable recovery time objective MUST be 4 hours.</data>
      <data key="d7">rules</data>
    </node>
    <node id="SLO-REC-004">
      <data key="d0">rule</data>
      <data key="d1">rule: SLO-REC-004</data>
      <data key="d6">A recovery drill MUST be performed at least once every 90 days.</data>
      <data key="d7">rules</data>
    </node>
    <node id="SLO-RG-001">
      <data key="d0">rule</data>
      <data key="d1">rule: SLO-RG-001</data>
      <data key="d6">Release verification MUST confirm that health-check release gate checks defined in specs/05_testing_operations.yaml pass.</data>
      <data key="d7">release_gate_rules</data>
    </node>
    <node id="SLO-RG-002">
      <data key="d0">rule</data>
      <data key="d1">rule: SLO-RG-002</data>
      <data key="d6">A release MUST NOT knowingly ship with a broken backup path.</data>
      <data key="d7">release_gate_rules</data>
    </node>
    <node id="SLO-RG-003">
      <data key="d0">rule</data>
      <data key="d1">rule: SLO-RG-003</data>
      <data key="d6">A release MUST record an operational blocker when current measurements show a breach of a defined availability, latency, device, or recovery target.</data>
      <data key="d7">release_gate_rules</data>
    </node>
    <node id="PCP-001">
      <data key="d0">rule</data>
      <data key="d1">rule: PCP-001</data>
      <data key="d6">The platform control plane MUST NOT expose tenant operational workflows.</data>
      <data key="d7">surface_rules</data>
    </node>
    <node id="PCP-002">
      <data key="d0">rule</data>
      <data key="d1">rule: PCP-002</data>
      <data key="d6">The platform control plane MUST NOT provide menu, order, station, checkout, or customer session management for a tenant.</data>
      <data key="d7">surface_rules</data>
    </node>
    <node id="PCP-003">
      <data key="d0">rule</data>
      <data key="d1">rule: PCP-003</data>
      <data key="d6">The platform control plane MAY inspect tenant lifecycle, provisioning, schema, activation, audit, and health metadata.</data>
      <data key="d7">surface_rules</data>
    </node>
    <node id="PCP-004">
      <data key="d0">rule</data>
      <data key="d1">rule: PCP-004</data>
      <data key="d6">The platform control plane MUST be served only from platform.iotables.net.</data>
      <data key="d7">surface_rules</data>
    </node>
    <node id="PCP-005">
      <data key="d0">rule</data>
      <data key="d1">rule: PCP-005</data>
      <data key="d6">Platform routes MUST use platform API routes under /api/platform/**.</data>
      <data key="d7">surface_rules</data>
    </node>
    <node id="PCP-006">
      <data key="d0">rule</data>
      <data key="d1">rule: PCP-006</data>
      <data key="d6">The platform control plane MUST use a Workspace-centric SaaS layout consisting of a three-pane view (Left Navigation Sidebar, Middle Master Grid/List, and Right Contextual Inspector Panel) to maximize context preservation and prevent full-page reloads.</data>
      <data key="d7">surface_rules</data>
    </node>
    <node id="PCP-007">
      <data key="d0">rule</data>
      <data key="d1">rule: PCP-007</data>
      <data key="d6">The Right Contextual Inspector Panel MUST display all selected tenant-specific details (Overview, Lifecycle, Provisioning, Database, Owner Activation, Jobs, Audit, and Health) using in-panel horizontal tab navigation to ensure a unified master-detail interface.</data>
      <data key="d7">surface_rules</data>
    </node>
    <node id="PCP-008">
      <data key="d0">rule</data>
      <data key="d1">rule: PCP-008</data>
      <data key="d6">Form submissions and interactive creation processes (such as Tenant Creation) MUST be built as overlay modal dialogs or multi-step onboarding wizards instead of separate full-page routes to retain parent view context.</data>
      <data key="d7">surface_rules</data>
    </node>
    <node id="PCP-009">
      <data key="d0">rule</data>
      <data key="d1">rule: PCP-009</data>
      <data key="d6">The platform control plane navigation and right-drawer states MUST be URL-aware (via query parameters or route interception) so that deep-linking and browser history support work seamlessly.</data>
      <data key="d7">surface_rules</data>
    </node>
    <node id="PCP-010">
      <data key="d0">rule</data>
      <data key="d1">rule: PCP-010</data>
      <data key="d6">A global keyboard-accessible Command Palette (Ctrl+K / Cmd+K) MUST be integrated to allow platform owners to instantly search and switch between tenants, jobs, or settings pages.</data>
      <data key="d7">surface_rules</data>
    </node>
    <node id="TCV-001">
      <data key="d0">rule</data>
      <data key="d1">rule: TCV-001</data>
      <data key="d6">Tenant display name is required.</data>
      <data key="d7">validation_rules</data>
    </node>
    <node id="TCV-002">
      <data key="d0">rule</data>
      <data key="d1">rule: TCV-002</data>
      <data key="d6">Tenant owner full name is required.</data>
      <data key="d7">validation_rules</data>
    </node>
    <node id="TCV-003">
      <data key="d0">rule</data>
      <data key="d1">rule: TCV-003</data>
      <data key="d6">Tenant owner email is required and MUST be a valid email address.</data>
      <data key="d7">validation_rules</data>
    </node>
    <node id="TCV-004">
      <data key="d0">rule</data>
      <data key="d1">rule: TCV-004</data>
      <data key="d6">Tenant slug MUST contain only lowercase ascii letters, digits, and hyphens.</data>
      <data key="d7">validation_rules</data>
    </node>
    <node id="TCV-005">
      <data key="d0">rule</data>
      <data key="d1">rule: TCV-005</data>
      <data key="d6">Tenant slug MUST be globally unique.</data>
      <data key="d7">validation_rules</data>
    </node>
    <node id="TCV-006">
      <data key="d0">rule</data>
      <data key="d1">rule: TCV-006</data>
      <data key="d6">Tenant slug MUST NOT be editable after tenant creation is confirmed.</data>
      <data key="d7">validation_rules</data>
    </node>
    <node id="TCV-007">
      <data key="d0">rule</data>
      <data key="d1">rule: TCV-007</data>
      <data key="d6">Tenant domain MUST be derived from tenant slug.</data>
      <data key="d7">validation_rules</data>
    </node>
    <node id="TCV-008">
      <data key="d0">rule</data>
      <data key="d1">rule: TCV-008</data>
      <data key="d6">Tenant database name MUST be derived from tenant slug.</data>
      <data key="d7">validation_rules</data>
    </node>
    <node id="TCV-009">
      <data key="d0">rule</data>
      <data key="d1">rule: TCV-009</data>
      <data key="d6">Platform owner MUST NOT manually enter tenant database name.</data>
      <data key="d7">validation_rules</data>
    </node>
    <node id="TCV-010">
      <data key="d0">rule</data>
      <data key="d1">rule: TCV-010</data>
      <data key="d6">Platform owner MUST NOT manually enter tenant id, provisioning job id, activation token, or connection metadata.</data>
      <data key="d7">validation_rules</data>
    </node>
    <node id="TCV-011">
      <data key="d0">rule</data>
      <data key="d1">rule: TCV-011</data>
      <data key="d6">Default locale, currency, timezone, and initial plan MUST have explicit values at creation time.</data>
      <data key="d7">validation_rules</data>
    </node>
    <node id="PDC-001">
      <data key="d0">rule</data>
      <data key="d1">rule: PDC-001</data>
      <data key="d6">Tenant slug MUST be globally unique and immutable after creation.</data>
      <data key="d7">constraint_rules</data>
    </node>
    <node id="PDC-002">
      <data key="d0">rule</data>
      <data key="d1">rule: PDC-002</data>
      <data key="d6">Tenant domain MUST be globally unique and follow {tenant}.iotables.net.</data>
      <data key="d7">constraint_rules</data>
    </node>
    <node id="PDC-003">
      <data key="d0">rule</data>
      <data key="d1">rule: PDC-003</data>
      <data key="d6">Tenant database name MUST be globally unique.</data>
      <data key="d7">constraint_rules</data>
    </node>
    <node id="PDC-004">
      <data key="d0">rule</data>
      <data key="d1">rule: PDC-004</data>
      <data key="d6">Platform audit log MUST be append-only.</data>
      <data key="d7">constraint_rules</data>
    </node>
    <node id="PDC-005">
      <data key="d0">rule</data>
      <data key="d1">rule: PDC-005</data>
      <data key="d6">platform_idempotency_keys MUST prevent duplicate execution of mutation requests with the same idempotency key.</data>
      <data key="d7">constraint_rules</data>
    </node>
    <node id="PDC-006">
      <data key="d0">rule</data>
      <data key="d1">rule: PDC-006</data>
      <data key="d6">connection_secret_ref MUST reference external secret storage and MUST NOT contain plaintext credentials.</data>
      <data key="d7">constraint_rules</data>
    </node>
    <node id="PDC-007">
      <data key="d0">rule</data>
      <data key="d1">rule: PDC-007</data>
      <data key="d6">Tenant lifecycle active MUST NOT imply tenant operations active.</data>
      <data key="d7">constraint_rules</data>
    </node>
    <node id="PDC-008">
      <data key="d0">rule</data>
      <data key="d1">rule: PDC-008</data>
      <data key="d6">Tenant owner activation invite records MUST be stored in the tenant database, not the platform database.</data>
      <data key="d7">constraint_rules</data>
    </node>
    <node id="EDI-001">
      <data key="d0">rule</data>
      <data key="d1">rule: EDI-001</data>
      <data key="d6">ESP32 devices MUST NOT generate QR tokens.</data>
      <data key="d7">security_rules</data>
    </node>
    <node id="EDI-002">
      <data key="d0">rule</data>
      <data key="d1">rule: EDI-002</data>
      <data key="d6">ESP32 devices MUST display only server-generated QR payloads.</data>
      <data key="d7">security_rules</data>
    </node>
    <node id="EDI-003">
      <data key="d0">rule</data>
      <data key="d1">rule: EDI-003</data>
      <data key="d6">Device secret MUST be revocable.</data>
      <data key="d7">security_rules</data>
    </node>
    <node id="EDI-004">
      <data key="d0">rule</data>
      <data key="d1">rule: EDI-004</data>
      <data key="d6">A device MUST be assigned to exactly one tenant table.</data>
      <data key="d7">security_rules</data>
    </node>
    <node id="EDI-005">
      <data key="d0">rule</data>
      <data key="d1">rule: EDI-005</data>
      <data key="d6">A table MAY have at most one active QR display device.</data>
      <data key="d7">security_rules</data>
    </node>
    <node id="EDI-006">
      <data key="d0">rule</data>
      <data key="d1">rule: EDI-006</data>
      <data key="d6">Device reconnect MUST NOT rotate QR by itself.</data>
      <data key="d7">security_rules</data>
    </node>
    <node id="EDI-007">
      <data key="d0">rule</data>
      <data key="d1">rule: EDI-007</data>
      <data key="d6">Server MUST remain source of truth for QR state.</data>
      <data key="d7">security_rules</data>
    </node>
    <node id="EDI-008">
      <data key="d0">rule</data>
      <data key="d1">rule: EDI-008</data>
      <data key="d6">Device messages MUST be tenant-scoped and table-scoped.</data>
      <data key="d7">security_rules</data>
    </node>
    <node id="EDI-009">
      <data key="d0">rule</data>
      <data key="d1">rule: EDI-009</data>
      <data key="d6">Revoked devices MUST NOT receive QR payloads.</data>
      <data key="d7">security_rules</data>
    </node>
    <node id="EDI-010">
      <data key="d0">rule</data>
      <data key="d1">rule: EDI-010</data>
      <data key="d6">Firmware artifacts, Wi-Fi credentials, and device secrets MUST NOT be logged in plaintext.</data>
      <data key="d7">security_rules</data>
    </node>
    <node id="EDI-011">
      <data key="d0">rule</data>
      <data key="d1">rule: EDI-011</data>
      <data key="d6">Firmware artifacts MUST be treated as tenant secrets.</data>
      <data key="d7">security_rules</data>
    </node>
    <node id="WDP-001">
      <data key="d0">rule</data>
      <data key="d1">rule: WDP-001</data>
      <data key="d6">All WebSocket communication between ESP32 and the backend MUST use the unified JSON event frame format containing exact 'event' and 'payload' keys.</data>
      <data key="d7">rules</data>
    </node>
    <node id="WDP-002">
      <data key="d0">rule</data>
      <data key="d1">rule: WDP-002</data>
      <data key="d6">ESP32 devices MUST send a 'heartbeat' event frame every 60 seconds.</data>
      <data key="d7">rules</data>
    </node>
    <node id="WDP-003">
      <data key="d0">rule</data>
      <data key="d1">rule: WDP-003</data>
      <data key="d6">The backend MUST disconnect the WebSocket if no frame is received within 120 seconds.</data>
      <data key="d7">rules</data>
    </node>
    <node id="WDP-004">
      <data key="d0">rule</data>
      <data key="d1">rule: WDP-004</data>
      <data key="d6">The backend MUST send 'qr_update' frames when a customer session begins or rotates, containing a valid target URL and epoch expiration timestamp.</data>
      <data key="d7">rules</data>
    </node>
    <node id="WDP-005">
      <data key="d0">rule</data>
      <data key="d1">rule: WDP-005</data>
      <data key="d6">ESP32 firmware MUST implement an exponential backoff reconnection algorithm with random jitter up to a maximum of 300 seconds when disconnected.</data>
      <data key="d7">rules</data>
    </node>
    <node id="WDP-006">
      <data key="d0">rule</data>
      <data key="d1">rule: WDP-006</data>
      <data key="d6">The WebSocket connection manager MUST NOT queue historical 'qr_update' frames for offline or disconnected table devices.</data>
      <data key="d7">rules</data>
    </node>
    <node id="WDP-007">
      <data key="d0">rule</data>
      <data key="d1">rule: WDP-007</data>
      <data key="d6">For each active device, the server MUST buffer only the single, latest active 'qr_update' frame payload in Redis (with TTL matching the QR code expiration). All older or expired update payloads for that device MUST be overwritten or discarded immediately to prevent event storming and hardware memory exhaustion upon reconnection.</data>
      <data key="d7">rules</data>
    </node>
    <node id="DMR-001">
      <data key="d0">rule</data>
      <data key="d1">rule: DMR-001</data>
      <data key="d6">Platform and tenant databases MUST target PostgreSQL 17 exclusively.</data>
      <data key="d7">database_migration_rules</data>
    </node>
    <node id="DMR-002">
      <data key="d0">rule</data>
      <data key="d1">rule: DMR-002</data>
      <data key="d6">Schema migrations MUST be sequential, using Alembic with strict file naming V{Version}__{Description}.sql.</data>
      <data key="d7">database_migration_rules</data>
    </node>
    <node id="DMR-003">
      <data key="d0">rule</data>
      <data key="d1">rule: DMR-003</data>
      <data key="d6">All migrations MUST execute within an explicit database transaction unless they include commands like CREATE INDEX CONCURRENTLY which PostgreSQL prohibits inside transactions.</data>
      <data key="d7">database_migration_rules</data>
    </node>
    <node id="DMR-004">
      <data key="d0">rule</data>
      <data key="d1">rule: DMR-004</data>
      <data key="d6">Schema upgrades MUST strictly follow the Expand-Contract pattern to ensure database compatibility with both currently running and next-deploying API code versions.</data>
      <data key="d7">database_migration_rules</data>
    </node>
    <node id="DMR-005">
      <data key="d0">rule</data>
      <data key="d1">rule: DMR-005</data>
      <data key="d6">Naming of indexes, foreign keys, and unique constraints MUST follow deterministic naming schemas: 'idx_{table}_{column}', 'fk_{table}_{referenced_table}', and 'uq_{table}_{column}'.</data>
      <data key="d7">database_migration_rules</data>
    </node>
    <node id="DMR-006">
      <data key="d0">rule</data>
      <data key="d1">rule: DMR-006</data>
      <data key="d6">A failed schema migration on a specific tenant database MUST pause orchestration for that tenant immediately but MUST NOT block pending schema upgrades for other, independent tenant databases (failure isolation).</data>
      <data key="d7">database_migration_rules</data>
    </node>
    <node id="DMR-007">
      <data key="d0">rule</data>
      <data key="d1">rule: DMR-007</data>
      <data key="d6">To recover from transient network drops, the schema migration task engine MAY perform at most 1 automatic retry; if it fails again, it MUST flag the tenant registry with database_status = 'migration_failed' and schema_drift = true.</data>
      <data key="d7">database_migration_rules</data>
    </node>
    <node id="DMR-008">
      <data key="d0">rule</data>
      <data key="d1">rule: DMR-008</data>
      <data key="d6">Re-triggering a failed schema migration from the platform control plane MUST resume exactly from the failed migration version, leveraging transactional state tracking, and MUST NOT attempt to re-apply already completed migration steps.</data>
      <data key="d7">database_migration_rules</data>
    </node>
    <node id="DMR-009">
      <data key="d0">rule</data>
      <data key="d1">rule: DMR-009</data>
      <data key="d6">Dynamic Celery-driven or platform-triggered schema migrations executing on a tenant database MUST acquire a PostgreSQL advisory lock (or Redis distributed lock) for the targeted tenant slug prior to execution. Concurrently requested migration tasks for the same tenant MUST wait or fail-fast to guarantee strict mutual exclusion.</data>
      <data key="d7">database_migration_rules</data>
    </node>
