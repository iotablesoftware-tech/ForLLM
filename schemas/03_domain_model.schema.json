  "$defs": {
    "string_array": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "object_record": {
      "type": "object",
      "additionalProperties": true,
      "minProperties": 1
    },
    "module": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "scope",
        "responsibility",
        "owns_data",
        "owns_surfaces",
        "owns_api_families",
        "depends_on",
        "done_when"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "type": "string",
          "enum": [
            "platform_scope",
            "tenant_scope",
            "shared_scope",
            "external_scope"
          ]
        },
        "responsibility": {
          "type": "string",
          "minLength": 1
        },
        "owns_data": {
          "$ref": "#/$defs/string_array"
        },
        "owns_surfaces": {
          "$ref": "#/$defs/string_array"
        },
        "owns_api_families": {
          "$ref": "#/$defs/string_array"
        },
        "depends_on": {
          "$ref": "#/$defs/string_array"
        },
        "source_documents": {
          "$ref": "#/$defs/string_array"
        },
        "explicit_non_goals": {
          "$ref": "#/$defs/string_array"
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "accepted",
            "defined",
            "requires_decision"
          ]
        },
        "open_decision_refs": {
          "$ref": "#/$defs/string_array"
        },
        "done_when": {
          "$ref": "#/$defs/string_array"
        }
      }
    },
    "excluded_module": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "status",
        "reason"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["excluded", "phase_2"]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "initial_version_status": {
          "type": "string",
          "minLength": 1
        },
        "canonical_spec": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "rule_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "rule"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^MDR-[0-9]{3}$"
        },
        "rule": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "open_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "topic",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^SOR-[0-9]{3}$"
        },
        "topic": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "open",
            "accepted",
            "rejected"
          ]
        }
      }
    },
    "owner_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "topic",
        "decision"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^SOR-OD-[0-9]{3}$"
        },
        "topic": {
          "type": "string",
          "minLength": 1
        },
        "decision": {
          "type": "string",
          "enum": [
            "accepted",
            "rejected"
          ]
        }
      }
    },
    "authorization_rule": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "operation",
        "rules"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^PAR-[0-9]{3}$"
        },
        "operation": {
          "type": "string",
          "minLength": 1
        },
        "required_permission": {
          "type": "string"
        },
        "required_permissions": {
          "$ref": "#/$defs/string_array"
        },
        "rules": {
          "$ref": "#/$defs/string_array"
        }
      }
    }
  }
}